# ============================================================
# TicketFlow Frontend — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e ajuste os valores.
# NUNCA commite .env.local com valores reais no git.
# Adicione .env.local ao seu .gitignore.

# URL do API Gateway (ponto único de entrada do backend)
# Desenvolvimento local: porta 8080
VITE_API_URL=http://localhost:8080

# Em staging/produção, use a URL real:
# VITE_API_URL=https://api.ticketflow.com.br
